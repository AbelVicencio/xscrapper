{
  "manifest_version": 3,
  "name": "X Content Scraper",
  "version": "1.20",
  "description": "Extrae información estructurada de tarjetas de contenido en X.com de forma pasiva",
  "permissions": [
    "storage",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "background": {
    "service_worker": "dist/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "dist/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "X Content Scraper"
  },
  "icons": {}
}